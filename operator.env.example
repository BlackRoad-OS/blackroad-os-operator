PORT=4000
REDIS_URL=redis://localhost:6379
BR_OS_OPERATOR_VERSION=0.0.1
BR_OS_OPERATOR_COMMIT=local
BR_OS_ENV=local
LOG_LEVEL=info
CATALOG_PATH=/app/agent-catalog/agents.yaml
BR_OS_OPERATOR_MAX_CONCURRENCY=10
BR_OS_OPERATOR_DEFAULT_TIMEOUT_SECONDS=300

# LLM Provider: set to "ollama" for local inference (no API key needed)
#               set to "openai" (default) for OpenAI cloud
LLM_PROVIDER=openai
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
