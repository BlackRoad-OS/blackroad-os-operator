PORT=4000
REDIS_URL=redis://localhost:6379
BR_OS_OPERATOR_VERSION=0.0.1
BR_OS_OPERATOR_COMMIT=local
BR_OS_ENV=local
LOG_LEVEL=info
CATALOG_PATH=/app/agent-catalog/agents.yaml
BR_OS_OPERATOR_MAX_CONCURRENCY=10
BR_OS_OPERATOR_DEFAULT_TIMEOUT_SECONDS=300

# Ollama — local LLM backend (no external provider required)
# All @copilot, @lucidia, @blackboxprogramming, and @ollama requests
# are routed directly to this endpoint.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:latest
